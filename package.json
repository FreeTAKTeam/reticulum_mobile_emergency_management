{
  "name": "reticulum_mobile_emergency_management",
  "private": true,
  "version": "0.8.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "web:dev": "npm --workspace apps/mobile run dev:web",
    "web:build": "npm --workspace apps/mobile run build:web",
    "mobile:dev": "npm --workspace apps/mobile run dev:mobile",
    "mobile:build": "npm --workspace apps/mobile run build:mobile",
    "node-client:build": "npm --workspace packages/node-client run build",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2"
  }
}

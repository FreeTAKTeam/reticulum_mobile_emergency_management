namespace reticulum_mobile {
  // Simple sanity check that the Rust library can be loaded and invoked.
  string healthcheck();
};

// Common enums.

enum LogLevel { "Trace", "Debug", "Info", "Warn", "Error" };

enum HubMode { "Autonomous", "SemiAutonomous", "Connected" };

enum PeerState { "Connecting", "Connected", "Disconnected" };

enum AnnounceClass { "PeerApp", "RchHubServer", "PropagationNode", "LxmfDelivery", "Other" };

enum SendOutcome {
  "SentDirect",
  "SentBroadcast",
  "DroppedMissingDestinationIdentity",
  "DroppedCiphertextTooLarge",
  "DroppedEncryptFailed",
  "DroppedNoRoute"
};

enum LxmfDeliveryStatus { "Sent", "SentToPropagation", "Acknowledged", "Failed", "TimedOut" };

enum SendMode { "Auto", "DirectOnly", "PropagationOnly" };

enum LxmfDeliveryMethod { "Direct", "Opportunistic", "Propagated" };

enum LxmfDeliveryRepresentation { "Packet", "Resource" };

enum LxmfFallbackStage { "AfterDirectRetryBudget" };

enum MessageMethod { "Direct", "Opportunistic", "Propagated", "Resource" };

enum MessageState {
  "Queued",
  "PathRequested",
  "LinkEstablishing",
  "Sending",
  "SentDirect",
  "SentToPropagation",
  "Delivered",
  "Failed",
  "TimedOut",
  "Cancelled",
  "Received"
};

enum MessageDirection { "Inbound", "Outbound" };

enum SosState { "Idle", "Countdown", "Sending", "Active" };

enum SosTriggerSource {
  "Manual",
  "FloatingButton",
  "Shake",
  "TapPattern",
  "PowerButton",
  "Restore",
  "Remote"
};

enum SosMessageKind { "Active", "Update", "Cancelled" };

enum ChecklistMode { "Online", "Offline" };

enum ChecklistSyncState { "LocalOnly", "UploadPending", "Synced" };

enum ChecklistOriginType {
  "RchTemplate",
  "BlankTemplate",
  "CsvImport",
  "ExistingTemplateClone"
};

enum ChecklistUserTaskStatus { "Pending", "Complete" };

enum ChecklistTaskStatus { "Pending", "Complete", "CompleteLate", "Late" };

enum ChecklistColumnType {
  "ShortString",
  "LongString",
  "Integer",
  "ActualTime",
  "RelativeTime"
};

enum ChecklistSystemColumnKey { "DueRelativeDtg" };

enum SyncPhase {
  "Idle",
  "PathRequested",
  "LinkEstablishing",
  "RequestSent",
  "Receiving",
  "Complete",
  "Failed"
};

enum ProjectionScope {
  "AppSettings",
  "SavedPeers",
  "OperationalSummary",
  "Peers",
  "SyncStatus",
  "HubRegistration",
  "Checklists",
  "ChecklistDetail",
  "Eams",
  "Events",
  "Conversations",
  "Messages",
  "Telemetry",
  "Sos"
};

// Error surface.

[Error]
enum NodeError {
  "InvalidConfig",
  "IoError",
  "NetworkError",
  "ReticulumError",
  "AlreadyRunning",
  "NotRunning",
  "Timeout",
  "LxmfWireEncodeError",
  "LxmfMessageIdParseError",
  "LxmfPacketTooLarge",
  "LxmfPacketBuildError",
  "EventStreamClosed",
  "InternalError"
};

// Configuration & status dictionaries.

dictionary NodeConfig {
  // Friendly node name used for diagnostics.
  string name;

  // Optional filesystem directory for persistent state (identity, ratchets).
  // When omitted, an in-memory identity derived from `name` is used.
  string? storage_dir;

  // TCP client interfaces to join (host:port), e.g. "rmap.world:4242".
  sequence<string> tcp_clients;

  // Transport broadcast mode (true enables broadcast for discovery/path requests).
  boolean broadcast;

  // Periodic announce interval for the app destination.
  u32 announce_interval_seconds;

  // Peer route/announce staleness window for UI projections.
  u32 stale_after_minutes;

  // App capabilities emitted as UTF-8 app_data in announces (comma-separated).
  string announce_capabilities;

  // Hub directory settings (optional).
  HubMode hub_mode;
  string? hub_identity_hash;
  string? hub_api_base_url;
  string? hub_api_key;
  u32 hub_refresh_interval_seconds;
};

dictionary NodeStatus {
  boolean running;
  string name;
  string identity_hex;
  string app_destination_hex;
  string lxmf_destination_hex;
};

dictionary PeerChange {
  string destination_hex;
  string? identity_hex;
  string? lxmf_destination_hex;
  string? display_name;
  string? app_data;
  PeerState state;
  boolean saved;
  boolean stale;
  boolean active_link;
  string? last_error;
  string? last_resolution_error;
  u64? last_resolution_attempt_at_ms;
  u64 last_seen_at_ms;
  u64? announce_last_seen_at_ms;
  u64? lxmf_last_seen_at_ms;
};

dictionary LxmfDeliveryUpdate {
  string message_id_hex;
  string destination_hex;
  string? source_hex;
  string? correlation_id;
  string? command_id;
  string? command_type;
  string? event_uid;
  string? mission_uid;
  LxmfDeliveryStatus status;
  LxmfDeliveryMethod method;
  LxmfDeliveryRepresentation representation;
  string? relay_destination_hex;
  LxmfFallbackStage? fallback_stage;
  string? detail;
  u64 sent_at_ms;
  u64 updated_at_ms;
};

dictionary AnnounceRecord {
  string destination_hex;
  string identity_hex;
  string destination_kind;
  AnnounceClass announce_class;
  string app_data;
  string? display_name;
  u8 hops;
  string interface_hex;
  u64 received_at_ms;
};

dictionary PeerRecord {
  string destination_hex;
  string? identity_hex;
  string? lxmf_destination_hex;
  string? display_name;
  string? app_data;
  PeerState state;
  boolean saved;
  boolean stale;
  boolean active_link;
  boolean hub_derived;
  string? last_resolution_error;
  u64? last_resolution_attempt_at_ms;
  u64 last_seen_at_ms;
  u64? announce_last_seen_at_ms;
  u64? lxmf_last_seen_at_ms;
};

dictionary ConversationRecord {
  string conversation_id;
  string peer_destination_hex;
  string? peer_display_name;
  string? last_message_preview;
  u64 last_message_at_ms;
  u32 unread_count;
  MessageState? last_message_state;
};

dictionary MessageRecord {
  string message_id_hex;
  string conversation_id;
  MessageDirection direction;
  string destination_hex;
  string? source_hex;
  string? title;
  string body_utf8;
  MessageMethod method;
  MessageState state;
  string? detail;
  u64? sent_at_ms;
  u64? received_at_ms;
  u64 updated_at_ms;
};

dictionary SyncStatus {
  SyncPhase phase;
  string? active_propagation_node_hex;
  u64? requested_at_ms;
  u64? completed_at_ms;
  u32 messages_received;

  string? key;
  u64 revision;
  u64 updated_at_ms;
  string? reason;
};

dictionary OperationalSummary {
  boolean running;
  u32 peer_count_total;
  u32 saved_peer_count;
  u32 connected_peer_count;
  u32 conversation_count;
  u32 message_count;
  u32 eam_count;
  u32 event_count;
  u32 telemetry_count;
  string? active_propagation_node_hex;
  u64 updated_at_ms;
};

dictionary OperationalNotice {
  LogLevel level;
  string message;
  u64 at_ms;
};

// Event stream from the node to the UI.
[Enum]
interface NodeEvent {
  StatusChanged(NodeStatus status);
  AnnounceReceived(
    string destination_hex,
    string identity_hex,
    string destination_kind,
    AnnounceClass announce_class,
    string app_data,
    string? display_name,
    u8 hops,
    string interface_hex,
    u64 received_at_ms
  );
  PeerChanged(PeerChange change);
  PacketReceived(string destination_hex, string? source_hex, sequence<u8> bytes, sequence<u8>? fields_bytes);
  PacketSent(string destination_hex, sequence<u8> bytes, SendOutcome outcome);
  LxmfDelivery(LxmfDeliveryUpdate update);
  PeerResolved(PeerRecord peer);
  MessageReceived(MessageRecord message);
  MessageUpdated(MessageRecord message);
  SyncUpdated(SyncStatus status);
  HubDirectoryUpdated(HubDirectorySnapshot snapshot);
  OperationalNotice(OperationalNotice notice);
  ProjectionInvalidated(ProjectionInvalidation invalidation);
  SosStatusChanged(SosStatusRecord status);
  SosAlertChanged(SosAlertRecord alert);
  SosTelemetryRequested();
  SosAudioRecordingRequested(string incident_id, u32 duration_seconds);
  Log(LogLevel level, string message);
  Error(string code, string message);
};

interface EventSubscription {
  NodeEvent? next(u32 timeout_ms);
  void close();
};

interface Node {
  constructor();

  [Throws=NodeError]
  void start(NodeConfig config);
  [Throws=NodeError]
  void stop();
  [Throws=NodeError]
  void restart(NodeConfig config);

  NodeStatus get_status();

  [Throws=NodeError]
  void connect_peer(string destination_hex);
  [Throws=NodeError]
  void disconnect_peer(string destination_hex);

  [Throws=NodeError]
  void send_bytes(
    string destination_hex,
    sequence<u8> bytes,
    sequence<u8>? fields_bytes,
    SendMode send_mode
  );
  [Throws=NodeError]
  void broadcast_bytes(sequence<u8> bytes);
  [Throws=NodeError]
  void announce_now();
  [Throws=NodeError]
  void request_peer_identity(string destination_hex);
  [Throws=NodeError]
  string send_lxmf(SendLxmfRequest request);
  [Throws=NodeError]
  void retry_lxmf(string message_id_hex);
  [Throws=NodeError]
  void cancel_lxmf(string message_id_hex);
  [Throws=NodeError]
  void set_active_propagation_node(string? destination_hex);
  [Throws=NodeError]
  void request_lxmf_sync(u32? limit);

  [Throws=NodeError]
  sequence<AnnounceRecord> list_announces();
  [Throws=NodeError]
  sequence<PeerRecord> list_peers();
  [Throws=NodeError]
  sequence<ConversationRecord> list_conversations();
  [Throws=NodeError]
  sequence<MessageRecord> list_messages(string? conversation_id);
  [Throws=NodeError]
  SyncStatus get_lxmf_sync_status();
  [Throws=NodeError]
  sequence<string> list_telemetry_destinations();

  [Throws=NodeError]
  boolean legacy_import_completed();
  [Throws=NodeError]
  void import_legacy_state(LegacyImportPayload payload);
  [Throws=NodeError]
  AppSettingsRecord? get_app_settings();
  [Throws=NodeError]
  void set_app_settings(AppSettingsRecord settings);
  [Throws=NodeError]
  sequence<SavedPeerRecord> get_saved_peers();
  [Throws=NodeError]
  void set_saved_peers(sequence<SavedPeerRecord> peers);
  [Throws=NodeError]
  OperationalSummary get_operational_summary();
  [Throws=NodeError]
  sequence<EamProjectionRecord> get_eams();
  [Throws=NodeError]
  void upsert_eam(EamProjectionRecord record);
  [Throws=NodeError]
  void delete_eam(string callsign, u64 deleted_at_ms);
  [Throws=NodeError]
  EamTeamSummaryRecord? get_eam_team_summary(string team_uid);
  [Throws=NodeError]
  sequence<EventProjectionRecord> get_events();
  [Throws=NodeError]
  void upsert_event(EventProjectionRecord record);
  [Throws=NodeError]
  void delete_event(string uid, u64 deleted_at_ms);
  [Throws=NodeError]
  sequence<ChecklistRecord> list_active_checklists(ChecklistListActiveRequest? request);
  [Throws=NodeError]
  ChecklistRecord? get_checklist(string checklist_uid);
  [Throws=NodeError]
  void create_online_checklist(ChecklistCreateOnlineRequest request);
  [Throws=NodeError]
  void update_checklist(ChecklistUpdateRequest request);
  [Throws=NodeError]
  void delete_checklist(string checklist_uid);
  [Throws=NodeError]
  void join_checklist(string checklist_uid);
  [Throws=NodeError]
  void set_checklist_task_status(ChecklistTaskStatusSetRequest request);
  [Throws=NodeError]
  void add_checklist_task_row(ChecklistTaskRowAddRequest request);
  [Throws=NodeError]
  void delete_checklist_task_row(ChecklistTaskRowDeleteRequest request);
  [Throws=NodeError]
  void set_checklist_task_row_style(ChecklistTaskRowStyleSetRequest request);
  [Throws=NodeError]
  void set_checklist_task_cell(ChecklistTaskCellSetRequest request);
  [Throws=NodeError]
  sequence<TelemetryPositionRecord> get_telemetry_positions();
  [Throws=NodeError]
  void record_local_telemetry_fix(TelemetryPositionRecord position);
  [Throws=NodeError]
  void delete_local_telemetry(string callsign);
  [Throws=NodeError]
  SosSettingsRecord get_sos_settings();
  [Throws=NodeError]
  void set_sos_settings(SosSettingsRecord settings);
  [Throws=NodeError]
  void set_sos_pin(string? pin);
  [Throws=NodeError]
  SosStatusRecord get_sos_status();
  [Throws=NodeError]
  SosStatusRecord trigger_sos(SosTriggerSource source);
  [Throws=NodeError]
  SosStatusRecord deactivate_sos(string? pin);
  [Throws=NodeError]
  void submit_sos_device_telemetry(SosDeviceTelemetryRecord telemetry);
  [Throws=NodeError]
  SosStatusRecord? submit_sos_accelerometer_sample(f64 x, f64 y, f64 z, u64 at_ms);
  [Throws=NodeError]
  SosStatusRecord? submit_sos_screen_event(u64 at_ms);
  [Throws=NodeError]
  sequence<SosAlertRecord> list_sos_alerts();
  [Throws=NodeError]
  sequence<SosLocationRecord> list_sos_locations();
  [Throws=NodeError]
  sequence<SosAudioRecord> list_sos_audio();

  [Throws=NodeError]
  void set_announce_capabilities(string capability_string);

  void set_log_level(LogLevel level);

  EventSubscription subscribe_events();

  // Trigger a one-shot hub directory refresh.
  [Throws=NodeError]
  void refresh_hub_directory();
};
